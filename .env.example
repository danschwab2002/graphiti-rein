# Copiar este archivo como .env y completar los valores
# En Easypanel estos se configuran como variables de entorno del servicio

# Neo4j — debe coincidir con la config del servicio Neo4j en Easypanel
NEO4J_URI=bolt://neo4j:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=cambia_esta_password_segura

# OpenAI — key fija de la plataforma RE(IN) para uso interno de Graphiti
OPENAI_API_KEY=sk-...

# Token secreto para proteger los endpoints (generá uno random)
# n8n lo enviará en cada request como campo "secret"
# Podés generarlo con: python -c "import secrets; print(secrets.token_hex(32))"
API_SECRET=genera_un_token_random_aqui
